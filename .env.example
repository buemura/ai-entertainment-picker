# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/entertainment_picker

# NextAuth
AUTH_SECRET=your-secret-here
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# LLM API
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# TMDB API (opcional por enquanto)
TMDB_API_KEY=your-tmdb-api-key

# Limite diário de recomendações por usuário
DAILY_LIMIT=3

# Whitelist: emails separados por vírgula com limite diário maior
WHITELIST_EMAILS=
WHITELIST_DAILY_LIMIT=50